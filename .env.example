# CyberSynth IDS environment variables
# Copy this file to .env and adjust values for your machine.

# Maximum CSV upload size in megabytes.
CYBERSYNTH_MAX_UPLOAD_MB=25

# Maximum compute-heavy API requests per IP per 60 seconds.
# Applies to prediction, CSV validation/scoring, generation, explain, and drift routes.
CYBERSYNTH_RATE_LIMIT=30

# Optional API key protection.
# Leave blank for local development.
# When set, clients must send: X-API-Key: <value>
CYBERSYNTH_API_KEY=

# Optional admin protection for model reload and admin audit-log access.
# Leave blank for local development.
# When set, clients must send: X-Admin-Token: <value>
CYBERSYNTH_ADMIN_TOKEN=

# Optional SHA-256 hash of models/baseline_lightgbm.joblib.
# When set, the server refuses to load a model file with a different hash.
CYBERSYNTH_MODEL_SHA256=

# Maximum seconds a synthetic dataset generation request may run.
CYBERSYNTH_GEN_TIMEOUT=600

# Comma-separated origins allowed to call the API from a browser.
CYBERSYNTH_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Use production to hide filesystem paths in API responses.
APP_ENV=development
